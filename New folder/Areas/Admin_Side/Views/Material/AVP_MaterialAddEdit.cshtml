
@{
    ViewData["Title"] = "Material AddEdit";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


@model Aryavarta.Areas.Admin_Side.Models.MaterialModel


<div class="content-body" style="min-height: 924px;">
    <div class="container-fluid">
        <div class="col-12">
            <div class="page-content-wrapper">

        <div class="page-content" style="min-height: 396px;">

            <div class="container portlet light bordered">

                <div class="portlet-title">
                    <div class="caption">
                        <span class="caption-subject font-dark sbold uppercase">Material Add-Edit Form</span>
                    </div>
                </div>
                <div class="form">

                    <h3 style="color: green;"> @TempData["MaterialInsertMsg"] </h3>

                    <form method="post" asp-area="Admin_Side" asp-controller="Material" asp-action="Save" class="container" role="form" enctype="multipart/form-data">
                        <div class="form-body">

                            @Html.HiddenFor(x=>x.MaterialID)

                            <div class="form-body">
                                <div class="form-group">
                                    <label class="col-md-3 control-label"> Material Type </label>
                                    <div class="col-md-9">
                                        <input type="text" asp-for="MaterialType" class="form-control" placeholder="Enter Material Type">
                                        <span asp-validation-for="MaterialType" class="text-danger">  </span>
                                    </div>
                                </div>
                            </div>

                            @*<div class="form-body">
                                <div class="form-group">
                                    <label class="col-md-3 control-label"> Creation Date </label>
                                    <div class="col-md-9">
                                        <input type="date" asp-for="CreationDate" class="form-control" placeholder="Enter Creation Date">
                                        <span asp-validation-for="CreationDate" class="text-danger">  </span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-body">
                                <div class="form-group">
                                    <label class="col-md-3 control-label"> Modification date </label>
                                    <div class="col-md-9">
                                        <input type="date" asp-for="ModificationDate" class="form-control" placeholder="Enter Modification date">
                                        <span asp-validation-for="ModificationDate" class="text-danger">  </span>
                                    </div>
                                </div>
                            </div>*@

                        </div>
                        <div class="form-actions">
                            <div class="row">
                                <div class="col-md-offset-3 col-md-9">
                                    <button type="submit" class="btn green" style="background-color:#425159; color:#f68b1f;">Submit</button>
                                    <button type="button" class="btn default" style="background-color:#425159; color:#f68b1f;" onclick="location.href='@Url.Action("Index")';">Cancel</button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

            </div>

        </div>

    </div>
        </div>
    </div>
</div>

@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}